{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Vitepress Example",
  "version": "0.2.0",
  "identifier": "com.vitepress-example.dev",
  "build": {
    "frontendDist": "dist",
    "devUrl": "http://localhost:5173/",
    "beforeDevCommand": "npm run docs:dev",
    "beforeBuildCommand": "npm run docs:build-tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Vitepress Example",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "/vitepress-example/index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
